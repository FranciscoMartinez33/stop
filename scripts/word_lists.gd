class_name WordLists

static func normalize_word(word: String) -> String:
	const MAP: Dictionary = {
		"À":"A","Á":"A","Â":"A","Ã":"A","Ä":"A","Å":"A",
		"à":"A","á":"A","â":"A","ã":"A","ä":"A","å":"A",
		"È":"E","É":"E","Ê":"E","Ë":"E",
		"è":"E","é":"E","ê":"E","ë":"E",
		"Ì":"I","Í":"I","Î":"I","Ï":"I",
		"ì":"I","í":"I","î":"I","ï":"I",
		"Ò":"O","Ó":"O","Ô":"O","Õ":"O","Ö":"O",
		"ò":"O","ó":"O","ô":"O","õ":"O","ö":"O",
		"Ù":"U","Ú":"U","Û":"U","Ü":"U",
		"ù":"U","ú":"U","û":"U","ü":"U",
		"Ñ":"N","ñ":"N",
		"Ç":"C","ç":"C",
		"Ý":"Y","ý":"Y",
		"Š":"S","š":"S","Ś":"S","ś":"S",
		"Ž":"Z","ž":"Z","Ź":"Z","ź":"Z",
		"Ř":"R","ř":"R",
		"Č":"C","č":"C","Ć":"C","ć":"C",
		"Ě":"E","ě":"E",
		"Ď":"D","ď":"D",
		"Ľ":"L","ľ":"L",
		"Ń":"N","ń":"N",
	}
	var result := ""
	for ch in word.to_upper():
		result += MAP.get(ch, ch)
	return result

## Returns true when `word` is valid for the given `topic`.
## Unknown topics always pass so future cards never break the game.
static func has_word(topic: String, word: String) -> bool:
	var key := topic.strip_edges().to_upper()
	if not _WORDS.has(key):
		return true
	var normalized := normalize_word(word.strip_edges())
	for entry in (_WORDS[key] as Array):
		if normalize_word(entry) == normalized:
			return true
	return false

